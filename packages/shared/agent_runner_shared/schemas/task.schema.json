{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runner/schemas/task.schema.json",
  "title": "Task Corpus Entry",
  "description": "A single evaluable task with pinned substrate, workflow, agents, and dual-format acceptance criteria.",
  "type": "object",
  "required": ["id", "version", "title", "substrate", "workflow", "acceptance_criteria"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "version": {"type": "integer", "minimum": 1},
    "title": {"type": "string"},
    "difficulty": {"type": "string", "enum": ["easy", "medium", "hard"]},
    "tags": {"type": "array", "items": {"type": "string"}},
    "substrate": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": {"type": "string"}
      }
    },
    "workflow": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {"type": "string"},
        "version": {"type": "integer", "minimum": 1}
      }
    },
    "agents": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*@[A-Za-z0-9._-]+$"}
    },
    "inputs": {"type": "object"},
    "models": {
      "type": "object",
      "properties": {
        "worker": {"type": "string"},
        "judge": {"type": "string"}
      }
    },
    "seed": {"type": "integer"},
    "acceptance_criteria": {
      "type": "object",
      "properties": {
        "deterministic": {
          "type": "array",
          "items": {"$ref": "#/$defs/deterministic_criterion"}
        },
        "rubric": {
          "type": "array",
          "items": {"$ref": "#/$defs/rubric_criterion"}
        }
      },
      "anyOf": [
        {"required": ["deterministic"]},
        {"required": ["rubric"]}
      ]
    },
    "calibration": {
      "type": "object",
      "required": ["model", "runs", "target_pass_rate"],
      "properties": {
        "model": {"type": "string"},
        "runs": {"type": "integer", "minimum": 1},
        "target_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "recorded_at": {"type": "string"},
        "measured_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "band": {
          "type": "object",
          "properties": {
            "low": {"type": "number"},
            "high": {"type": "number"}
          }
        }
      }
    }
  },
  "$defs": {
    "deterministic_criterion": {
      "type": "object",
      "required": ["id", "description", "kind"],
      "properties": {
        "id": {"type": "string"},
        "description": {"type": "string"},
        "kind": {"type": "string", "enum": ["file_exists", "script", "event_assertion", "schema_valid"]},
        "path": {"type": "string"},
        "script": {"type": "string"},
        "event": {"type": "object"},
        "schema": {"type": "string"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "file_exists"}}}, "then": {"required": ["path"]}},
        {"if": {"properties": {"kind": {"const": "script"}}},      "then": {"required": ["script"]}},
        {"if": {"properties": {"kind": {"const": "event_assertion"}}}, "then": {"required": ["event"]}},
        {"if": {"properties": {"kind": {"const": "schema_valid"}}},  "then": {"required": ["path", "schema"]}}
      ]
    },
    "rubric_criterion": {
      "type": "object",
      "required": ["id", "description", "scale", "threshold", "judge_prompt"],
      "properties": {
        "id": {"type": "string"},
        "description": {"type": "string"},
        "scale": {"type": "string", "pattern": "^[0-9]+-[0-9]+$"},
        "threshold": {"type": "number"},
        "judge_prompt": {"type": "string"}
      }
    }
  }
}
