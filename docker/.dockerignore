# Docker build context excludes
#
# These patterns are excluded from the Docker build context to keep
# builds fast and avoid leaking local state into images.

# Runtime outputs
runs/
cassettes/
baselines/

# Version control
.git/
.gitignore

# Python bytecode
*.pyc
*.pyo
__pycache__/
*.egg-info/
.eggs/
dist/
build/

# Environment files
.env
.env.*
*.env

# Editor metadata
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Test caches
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Local docs/notebooks not needed in image
docs/
*.ipynb
